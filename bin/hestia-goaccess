#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/.." && pwd)"

if [[ -f "${repo_root}/conf/defaults.conf" ]]; then
	# shellcheck disable=SC1091
	source "${repo_root}/conf/defaults.conf"
elif [[ -f /etc/hestia-goaccess/defaults.conf ]]; then
	# shellcheck disable=SC1091
	source /etc/hestia-goaccess/defaults.conf
elif [[ -f /usr/local/share/hestia-goaccess/conf/defaults.conf ]]; then
	# shellcheck disable=SC1091
	source /usr/local/share/hestia-goaccess/conf/defaults.conf
else
	printf 'hestia-goaccess: defaults.conf not found\n' >&2
	exit 1
fi

HESTIA_BIN="${HESTIA_BIN:-/usr/local/hestia/bin}"
HESTIA_DATA="${HESTIA_DATA:-/usr/local/hestia/data}"
STATE_DIR="${HESTIA_GOACCESS_STATE_DIR:-/etc/hestia-goaccess}"
STATE_DOMAIN_DIR="${STATE_DIR}/domains"
GOACCESS_RUN_DIR="${HESTIA_GOACCESS_RUN_DIR:-/run/hestia-goaccess}"
if [[ -x "${repo_root}/scripts/hestia-goaccess-filter-log" ]]; then
	DEFAULT_GOACCESS_FILTER_LOG="${repo_root}/scripts/hestia-goaccess-filter-log"
	DEFAULT_GOACCESS_REALTIME_RUNNER="${repo_root}/scripts/hestia-goaccess-realtime-runner"
else
	DEFAULT_GOACCESS_FILTER_LOG="/usr/local/share/hestia-goaccess/scripts/hestia-goaccess-filter-log"
	DEFAULT_GOACCESS_REALTIME_RUNNER="/usr/local/share/hestia-goaccess/scripts/hestia-goaccess-realtime-runner"
fi
GOACCESS_FILTER_LOG="${HESTIA_GOACCESS_FILTER_LOG:-${GOACCESS_FILTER_LOG:-${DEFAULT_GOACCESS_FILTER_LOG}}}"
GOACCESS_REALTIME_RUNNER="${HESTIA_GOACCESS_REALTIME_RUNNER:-${GOACCESS_REALTIME_RUNNER:-${DEFAULT_GOACCESS_REALTIME_RUNNER}}}"
GOACCESS_LOG_FORMAT="${HESTIA_GOACCESS_LOG_FORMAT:-${GOACCESS_LOG_FORMAT:-COMBINED}}"
GOACCESS_IGNORE_PATHS="${HESTIA_GOACCESS_IGNORE_PATHS:-${GOACCESS_IGNORE_PATHS:-/vstats/}}"
GOACCESS_HTML_PREFS="${HESTIA_GOACCESS_HTML_PREFS:-${GOACCESS_HTML_PREFS:-{\"theme\":\"darkGray\"}}"
GOACCESS_REALTIME_BIND="${GOACCESS_REALTIME_BIND:-127.0.0.1}"
GOACCESS_REALTIME_WS_PATH="${GOACCESS_REALTIME_WS_PATH:-/vstats/ws/}"
GOACCESS_REALTIME_WS_URL_TEMPLATE="${HESTIA_GOACCESS_REALTIME_WS_URL_TEMPLATE:-${GOACCESS_REALTIME_WS_URL_TEMPLATE:-}}"

usage() {
	cat <<'USAGE'
hestia-goaccess

Commands:
  doctor [USER DOMAIN]
  enable USER DOMAIN --mode static [--ignore-paths PATHS]
  enable USER DOMAIN --mode realtime [--ws-url URL] [--ignore-paths PATHS]
  disable USER DOMAIN
  status [USER DOMAIN]
  terminal [USER] DOMAIN
  help

Shortcuts:
  hestia-goaccess USER DOMAIN
  hestia-goaccess DOMAIN

Use Hestia's Web Statistics selector or v-change-web-domain-stats for normal
static/realtime enablement. The enable command is kept for direct admin use.
USAGE
}

die() {
	printf 'hestia-goaccess: %s\n' "$*" >&2
	exit 1
}

info() {
	printf '%s\n' "$*"
}

version_ge() {
	local current="$1"
	local minimum="$2"
	local first

	first="$(printf '%s\n%s\n' "${minimum}" "${current}" | sort -V | head -n 1)"
	[[ "${first}" == "${minimum}" ]]
}

validate_user() {
	[[ "${1:-}" =~ ^[A-Za-z0-9._-]+$ ]] || die "invalid Hestia user: ${1:-}"
}

validate_domain() {
	[[ "${1:-}" =~ ^[A-Za-z0-9._-]+$ ]] || die "invalid domain: ${1:-}"
}

require_hestia() {
	[[ -x "${HESTIA_BIN}/v-list-sys-config" ]] || die "Hestia CLI not found at ${HESTIA_BIN}"
}

require_goaccess() {
	local version

	if ! command -v goaccess >/dev/null 2>&1; then
		die "goaccess is not installed; minimum required version is ${GOACCESS_MIN_VERSION}"
	fi

	version="$(goaccess --version | sed -n 's/^GoAccess - \([0-9][0-9.]*[0-9]\).*/\1/p' | head -n 1)"
	[[ -n "${version}" ]] || die "unable to determine goaccess version"

	if ! version_ge "${version}" "${GOACCESS_MIN_VERSION}"; then
		die "goaccess ${version} is too old; minimum required version is ${GOACCESS_MIN_VERSION}"
	fi
}

require_filter_log() {
	[[ -x "${GOACCESS_FILTER_LOG}" ]] || die "log filter not found or not executable: ${GOACCESS_FILTER_LOG}"
}

require_realtime_runner() {
	[[ -x "${GOACCESS_REALTIME_RUNNER}" ]] || die "realtime runner not found or not executable: ${GOACCESS_REALTIME_RUNNER}"
}

hestia_version() {
	"${HESTIA_BIN}/v-list-sys-config" json |
		sed -n 's/.*"VERSION": "\([^"]*\)".*/\1/p' |
		head -n 1
}

require_hestia_version() {
	local version

	version="$(hestia_version)"
	[[ -n "${version}" ]] || die "unable to determine Hestia version"
	if ! version_ge "${version}" "1.9.4"; then
		die "Hestia ${version} is too old; minimum supported version is 1.9.4"
	fi
}

domain_line() {
	local user="$1"
	local domain="$2"
	local web_conf="${HESTIA_DATA}/users/${user}/web.conf"
	local line

	[[ -f "${web_conf}" ]] || return 1
	while IFS= read -r line; do
		case "${line}" in
			"DOMAIN='${domain}' "*) printf '%s\n' "${line}"; return 0 ;;
		esac
	done < "${web_conf}"

	return 1
}

domain_field() {
	local line="$1"
	local field="$2"

	printf '%s\n' "${line}" |
		sed -n "s/.* ${field}='\\([^']*\\)'.*/\\1/p"
}

require_domain() {
	local user="$1"
	local domain="$2"

	validate_user "${user}"
	validate_domain "${domain}"
	require_hestia

	domain_line "${user}" "${domain}" >/dev/null ||
		die "domain ${domain} was not found for Hestia user ${user}"
}

require_terminal_domain() {
	local user="$1"
	local domain="$2"

	validate_user "${user}"
	validate_domain "${domain}"

	if domain_line "${user}" "${domain}" >/dev/null; then
		return
	fi
	if [[ -d "/home/${user}/web/${domain}" ]]; then
		return
	fi

	die "domain ${domain} was not found for Hestia user ${user}"
}

domain_stats_path() {
	local user="$1"
	local domain="$2"

	printf '/home/%s/web/%s/stats\n' "${user}" "${domain}"
}

domain_public_scheme() {
	local line="$1"
	local ssl

	ssl="$(domain_field "${line}" "SSL")"
	if [[ "${ssl}" == "yes" ]]; then
		printf 'wss\n'
	else
		printf 'ws\n'
	fi
}

domain_log_path() {
	local domain="$1"
	local apache_log="/var/log/apache2/domains/${domain}.log"
	local nginx_log="/var/log/nginx/domains/${domain}.log"
	local apache_mtime
	local nginx_mtime

	if [[ -s "${apache_log}" && ! -s "${nginx_log}" ]]; then
		printf '%s\n' "${apache_log}"
	elif [[ -s "${nginx_log}" && ! -s "${apache_log}" ]]; then
		printf '%s\n' "${nginx_log}"
	elif [[ -s "${apache_log}" && -s "${nginx_log}" ]]; then
		apache_mtime="$(stat -c %Y "${apache_log}")"
		nginx_mtime="$(stat -c %Y "${nginx_log}")"
		if ((nginx_mtime > apache_mtime)); then
			printf '%s\n' "${nginx_log}"
		else
			printf '%s\n' "${apache_log}"
		fi
	elif [[ -f "${apache_log}" ]]; then
		printf '%s\n' "${apache_log}"
	elif [[ -f "${nginx_log}" ]]; then
		printf '%s\n' "${nginx_log}"
	else
		printf '%s\n' "${apache_log}"
	fi
}

state_file() {
	local user="$1"
	local domain="$2"

	printf '%s/%s/%s.conf\n' "${STATE_DOMAIN_DIR}" "${user}" "${domain}"
}

service_name() {
	local user="$1"
	local domain="$2"
	local safe_domain

	safe_domain="${domain//[^A-Za-z0-9]/_}"
	printf 'hestia-goaccess-%s-%s.service\n' "${user}" "${safe_domain}"
}

nginx_include_files() {
	local user="$1"
	local domain="$2"

	printf '/home/%s/conf/web/%s/nginx.conf_hestia_goaccess_realtime\n' "${user}" "${domain}"
	printf '/home/%s/conf/web/%s/nginx.ssl.conf_hestia_goaccess_realtime\n' "${user}" "${domain}"
}

expected_nginx_include_file() {
	local user="$1"
	local domain="$2"
	local line
	local ssl

	line="$(domain_line "${user}" "${domain}")"
	ssl="$(domain_field "${line}" "SSL")"
	if [[ "${ssl}" == "yes" ]]; then
		printf '/home/%s/conf/web/%s/nginx.ssl.conf_hestia_goaccess_realtime\n' "${user}" "${domain}"
	else
		printf '/home/%s/conf/web/%s/nginx.conf_hestia_goaccess_realtime\n' "${user}" "${domain}"
	fi
}

nginx_loads_include_file() {
	local include_file="$1"

	nginx -T 2>/dev/null | grep -Fq "# configuration file ${include_file}:"
}

validate_nginx_realtime_include_loaded() {
	local user="$1"
	local domain="$2"
	local include_file

	include_file="$(expected_nginx_include_file "${user}" "${domain}")"
	if ! nginx_loads_include_file "${include_file}"; then
		die "Nginx did not load ${include_file}. Use native Hestia Nginx templates with nginx.conf_* / nginx.ssl.conf_* include points, or add the standard include point to the active domain template."
	fi
}

write_state() {
	local user="$1"
	local domain="$2"
	local mode="$3"
	local log_path="$4"
	local report_path="$5"
	local port="${6:-}"
	local ws_url="${7:-}"
	local unit="${8:-}"
	local ignore_paths="${9:-${GOACCESS_IGNORE_PATHS}}"
	local html_prefs="${10:-${GOACCESS_HTML_PREFS}}"
	local log_format="${11:-${GOACCESS_LOG_FORMAT}}"
	local file

	file="$(state_file "${user}" "${domain}")"
	install -d -m 0755 "$(dirname "${file}")"
	cat > "${file}" <<STATE
HG_USER='${user}'
HG_DOMAIN='${domain}'
HG_MODE='${mode}'
HG_LOG_PATH='${log_path}'
HG_REPORT_PATH='${report_path}'
HG_PORT='${port}'
HG_WS_URL='${ws_url}'
HG_UNIT='${unit}'
HG_IGNORE_PATHS='${ignore_paths}'
HG_HTML_PREFS='${html_prefs}'
HG_LOG_FORMAT='${log_format}'
HG_UPDATED_AT='$(date -u +%Y-%m-%dT%H:%M:%SZ)'
STATE
	chmod 0644 "${file}"
}

systemd_env_escape() {
	local value="$1"

	value="${value//\\/\\\\}"
	value="${value//\"/\\\"}"
	printf '%s' "${value}"
}

state_value() {
	local file="$1"
	local key="$2"

	[[ -f "${file}" ]] || return 1
	sed -n "s/^${key}='\\([^']*\\)'$/\\1/p" "${file}" | head -n 1
}

check_log_format() {
	local log_path="$1"
	local output

	output="$(
		HESTIA_GOACCESS_IGNORE_PATHS="${GOACCESS_IGNORE_PATHS}" "${GOACCESS_FILTER_LOG}" "${log_path}" |
			goaccess - \
				--log-format="${GOACCESS_LOG_FORMAT}" \
				--process-and-exit \
				--num-tests=10 \
				--no-progress 2>&1 >/dev/null
	)" || die "access log did not parse with GoAccess log format '${GOACCESS_LOG_FORMAT}': ${output}"
}

check_realtime_log_access() {
	local user="$1"
	local log_path="$2"

	getent group adm >/dev/null || die "realtime mode requires the standard Debian/Ubuntu adm group to read Hestia log directories"
	command -v setpriv >/dev/null 2>&1 || die "setpriv is required to verify realtime log access"
	setpriv --reuid="${user}" --regid="${user}" --groups=adm test -r "${log_path}" ||
		die "realtime service would not be able to read ${log_path} as ${user} with supplementary group adm"
}

doctor() {
	local user="${1:-}"
	local domain="${2:-}"
	local version
	local line
	local stats
	local log_path
	local stats_path

	require_hestia
	require_hestia_version
	version="$(hestia_version)"
	info "ok: Hestia ${version}"

	require_goaccess
	info "ok: $(goaccess --version | head -n 1)"

	if [[ -n "${user}" || -n "${domain}" ]]; then
		[[ -n "${user}" && -n "${domain}" ]] || die "doctor requires both USER and DOMAIN when checking a domain"
		require_domain "${user}" "${domain}"
		line="$(domain_line "${user}" "${domain}")"
		stats="$(domain_field "${line}" "STATS")"
		log_path="$(domain_log_path "${domain}")"
		stats_path="$(domain_stats_path "${user}" "${domain}")"

		info "ok: domain ${user}/${domain} exists"
		info "info: Hestia STATS='${stats}'"

		[[ -d "${stats_path}" ]] || die "stats directory does not exist: ${stats_path}"
		info "ok: stats directory ${stats_path}"

		[[ -f "${log_path}" ]] || die "access log does not exist: ${log_path}"
		[[ -r "${log_path}" ]] || die "access log is not readable: ${log_path}"
		info "ok: access log ${log_path}"
		if [[ ! -s "${log_path}" ]]; then
			info "warn: access log is empty; static report generation will not be useful yet"
		else
			check_log_format "${log_path}"
			info "ok: access log parses as GoAccess log format '${GOACCESS_LOG_FORMAT}'"
		fi
		if [[ "${stats}" == "goaccess-realtime" ]]; then
			check_realtime_log_access "${user}" "${log_path}"
			info "ok: realtime service log access verified for ${user} with supplementary group adm"
		fi
	fi
}

enable_static() {
	local user="$1"
	local domain="$2"
	local log_path
	local stats_path
	local report_path
	local tmp_report
	local title
	local ignore_paths="${ENABLE_IGNORE_PATHS:-${GOACCESS_IGNORE_PATHS}}"
	local -a html_pref_args=()

	require_domain "${user}" "${domain}"
	require_hestia_version
	require_goaccess
	require_filter_log

	log_path="$(domain_log_path "${domain}")"
	stats_path="$(domain_stats_path "${user}" "${domain}")"
	report_path="${stats_path}/index.html"
	tmp_report="${report_path}.$$.html"
	title="${domain} GoAccess"
	if [[ -n "${GOACCESS_HTML_PREFS}" ]]; then
		html_pref_args=(--html-prefs="${GOACCESS_HTML_PREFS}")
	fi

	[[ -f "${log_path}" ]] || die "access log does not exist: ${log_path}"
	[[ -r "${log_path}" ]] || die "access log is not readable: ${log_path}"
	install -d -m 0755 -o "${user}" -g "${user}" "${stats_path}"

	HESTIA_GOACCESS_IGNORE_PATHS="${ignore_paths}" "${GOACCESS_FILTER_LOG}" "${log_path}" |
		goaccess - \
			--log-format="${GOACCESS_LOG_FORMAT}" \
			--anonymize-ip \
			--no-query-string \
			--ignore-crawlers \
			--html-report-title="${title}" \
			"${html_pref_args[@]}" \
			--output="${tmp_report}"

	mv "${tmp_report}" "${report_path}"
	chown "${user}:${user}" "${report_path}"
	chmod 0644 "${report_path}"
	stop_realtime_if_present "${user}" "${domain}"
	write_state "${user}" "${domain}" "static" "${log_path}" "${report_path}" "" "" "" "${ignore_paths}" "${GOACCESS_HTML_PREFS}" "${GOACCESS_LOG_FORMAT}"

	info "enabled static GoAccess report for ${user}/${domain}"
	info "report: ${report_path}"
	info "url: /vstats/"
}

port_in_range() {
	local port="$1"
	local start="$2"
	local end="$3"

	[[ "${port}" =~ ^[0-9]+$ ]] || return 1
	(( port >= start && port <= end ))
}

port_in_use_by_state() {
	local port="$1"
	local file
	local current

	if [[ -d "${STATE_DOMAIN_DIR}" ]]; then
		while IFS= read -r file; do
			current="$(state_value "${file}" "HG_PORT" || true)"
			[[ "${current}" == "${port}" ]] && return 0
		done < <(find "${STATE_DOMAIN_DIR}" -type f -name '*.conf' | sort)
	fi

	return 1
}

port_is_listening() {
	local port="$1"

	ss -ltn "sport = :${port}" 2>/dev/null | awk 'NR > 1 { found=1 } END { exit found ? 0 : 1 }'
}

allocate_port() {
	local user="$1"
	local domain="$2"
	local file
	local existing
	local start
	local end
	local port

	file="$(state_file "${user}" "${domain}")"
	existing="$(state_value "${file}" "HG_PORT" || true)"
	start="${GOACCESS_PORT_RANGE%-*}"
	end="${GOACCESS_PORT_RANGE#*-}"

	if port_in_range "${existing}" "${start}" "${end}"; then
		printf '%s\n' "${existing}"
		return
	fi

	for ((port = start; port <= end; port++)); do
		if port_in_use_by_state "${port}"; then
			continue
		fi
		if port_is_listening "${port}"; then
			continue
		fi
		printf '%s\n' "${port}"
		return
	done

	die "no available GoAccess realtime port in ${GOACCESS_PORT_RANGE}"
}

default_ws_url() {
	local user="$1"
	local domain="$2"
	local line
	local scheme
	local public_port
	local url

	line="$(domain_line "${user}" "${domain}")"
	scheme="$(domain_public_scheme "${line}")"
	if [[ -n "${GOACCESS_REALTIME_WS_URL_TEMPLATE}" ]]; then
		url="${GOACCESS_REALTIME_WS_URL_TEMPLATE//%domain%/${domain}}"
		url="${url//%scheme%/${scheme}}"
		printf '%s\n' "${url}"
		return
	fi
	if [[ "${scheme}" == "wss" ]]; then
		public_port="443"
	else
		public_port="80"
	fi
	printf '%s://%s:%s%s\n' "${scheme}" "${domain}" "${public_port}" "${GOACCESS_REALTIME_WS_PATH}"
}

write_nginx_realtime_include() {
	local user="$1"
	local domain="$2"
	local port="$3"
	local include_file

	while IFS= read -r include_file; do
		cat > "${include_file}" <<NGINX
location ~ ^/vstats/ws/?$ {
	include /home/${user}/web/${domain}/stats/auth.conf*;
	proxy_pass http://${GOACCESS_REALTIME_BIND}:${port};
	proxy_http_version 1.1;
	proxy_set_header Upgrade \$http_upgrade;
	proxy_set_header Connection "Upgrade";
	proxy_set_header Host \$host;
	proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
	proxy_set_header X-Forwarded-Proto \$scheme;
	proxy_read_timeout 1h;
	proxy_send_timeout 1h;
}
NGINX
		chown "${user}:${user}" "${include_file}"
		chmod 0644 "${include_file}"
	done < <(nginx_include_files "${user}" "${domain}")

	nginx -t >/dev/null
	validate_nginx_realtime_include_loaded "${user}" "${domain}"
	systemctl reload nginx
}

remove_nginx_realtime_include() {
	local user="$1"
	local domain="$2"
	local include_file
	local removed="no"

	while IFS= read -r include_file; do
		if [[ -f "${include_file}" ]]; then
			rm -f "${include_file}"
			removed="yes"
		fi
	done < <(nginx_include_files "${user}" "${domain}")
	if [[ "${removed}" == "yes" ]]; then
		nginx -t >/dev/null
		systemctl reload nginx
	fi
}

write_realtime_service() {
	local user="$1"
	local domain="$2"
	local log_path="$3"
	local report_path="$4"
	local port="$5"
	local ws_url="$6"
	local unit="$7"
	local unit_path="/etc/systemd/system/${unit}"
	local run_path="${GOACCESS_RUN_DIR}/${user}/${domain}"
	local ignore_paths="${ENABLE_IGNORE_PATHS:-${GOACCESS_IGNORE_PATHS}}"
	local escaped_ignore_paths
	local escaped_html_prefs
	local escaped_log_format

	escaped_ignore_paths="$(systemd_env_escape "${ignore_paths}")"
	escaped_html_prefs="$(systemd_env_escape "${GOACCESS_HTML_PREFS}")"
	escaped_log_format="$(systemd_env_escape "${GOACCESS_LOG_FORMAT}")"

	install -d -m 0755 -o "${user}" -g "${user}" "$(dirname "${report_path}")"
	if [[ -f "${report_path}" ]]; then
		chown "${user}:${user}" "${report_path}"
	fi
	install -d -m 0750 -o "${user}" -g "${user}" "${run_path}"

	cat > "${unit_path}" <<UNIT
[Unit]
Description=hestia-goaccess realtime report for ${user}/${domain}
After=network.target nginx.service

[Service]
Type=simple
User=${user}
Group=${user}
SupplementaryGroups=adm
WorkingDirectory=/home/${user}
Environment="HESTIA_GOACCESS_IGNORE_PATHS=${escaped_ignore_paths}"
Environment="HESTIA_GOACCESS_HTML_PREFS=${escaped_html_prefs}"
Environment="HESTIA_GOACCESS_LOG_FORMAT=${escaped_log_format}"
ExecStart=${GOACCESS_REALTIME_RUNNER} ${GOACCESS_FILTER_LOG} ${log_path} ${report_path} ${GOACCESS_REALTIME_BIND} ${port} ${ws_url} ${domain}
Restart=on-failure
RestartSec=5s
TimeoutStopSec=30s
KillMode=control-group
SendSIGKILL=yes
Nice=10
IOSchedulingClass=idle
PrivateTmp=true
NoNewPrivileges=true
ProtectSystem=full
ReadWritePaths=${run_path} $(dirname "${report_path}")

[Install]
WantedBy=multi-user.target
UNIT
	chmod 0644 "${unit_path}"
}

stop_realtime_if_present() {
	local user="$1"
	local domain="$2"
	local file
	local unit

	file="$(state_file "${user}" "${domain}")"
	unit="$(state_value "${file}" "HG_UNIT" || true)"
	if [[ -n "${unit}" ]] && systemctl list-unit-files "${unit}" >/dev/null 2>&1; then
		systemctl disable --now "${unit}" >/dev/null 2>&1 || true
		rm -f "/etc/systemd/system/${unit}"
		systemctl daemon-reload
	fi
	remove_nginx_realtime_include "${user}" "${domain}"
}

enable_realtime() {
	local user="$1"
	local domain="$2"
	local ws_url="$3"
	local log_path
	local stats_path
	local report_path
	local port
	local unit
	local ignore_paths="${ENABLE_IGNORE_PATHS:-${GOACCESS_IGNORE_PATHS}}"

	require_domain "${user}" "${domain}"
	require_hestia_version
	require_goaccess
	require_filter_log
	require_realtime_runner
	command -v systemctl >/dev/null 2>&1 || die "systemctl is required for realtime mode"
	command -v nginx >/dev/null 2>&1 || die "nginx is required for realtime WebSocket proxying"
	command -v ss >/dev/null 2>&1 || die "ss is required for realtime port allocation"

	log_path="$(domain_log_path "${domain}")"
	stats_path="$(domain_stats_path "${user}" "${domain}")"
	report_path="${stats_path}/index.html"
	port="$(allocate_port "${user}" "${domain}")"
	unit="$(service_name "${user}" "${domain}")"
	[[ -n "${ws_url}" ]] || ws_url="$(default_ws_url "${user}" "${domain}")"

	[[ -f "${log_path}" ]] || die "access log does not exist: ${log_path}"
	[[ -r "${log_path}" ]] || die "access log is not readable: ${log_path}"
	check_realtime_log_access "${user}" "${log_path}"

	stop_realtime_if_present "${user}" "${domain}"
	write_nginx_realtime_include "${user}" "${domain}" "${port}"
	write_realtime_service "${user}" "${domain}" "${log_path}" "${report_path}" "${port}" "${ws_url}" "${unit}"
	systemctl daemon-reload
	systemctl enable --now "${unit}"
	write_state "${user}" "${domain}" "realtime" "${log_path}" "${report_path}" "${port}" "${ws_url}" "${unit}" "${ignore_paths}" "${GOACCESS_HTML_PREFS}" "${GOACCESS_LOG_FORMAT}"

	info "enabled realtime GoAccess report for ${user}/${domain}"
	info "report: ${report_path}"
	info "url: /vstats/"
	info "websocket: ${ws_url}"
	info "service: ${unit}"
	info "ignored paths: ${ignore_paths}"
}

status_one() {
	local user="$1"
	local domain="$2"
	local line
	local stats
	local file
	local port=""
	local unit=""
	local ws_url=""
	local ignore_paths=""
	local html_prefs=""
	local log_format=""
	local mode="disabled"
	local HG_MODE=""
	local MODE=""

	require_domain "${user}" "${domain}"
	line="$(domain_line "${user}" "${domain}")"
	stats="$(domain_field "${line}" "STATS")"
	file="$(state_file "${user}" "${domain}")"

	if [[ -f "${file}" ]]; then
		# shellcheck disable=SC1090
		source "${file}"
		mode="${HG_MODE:-${MODE:-unknown}}"
		port="${HG_PORT:-}"
		unit="${HG_UNIT:-}"
		ws_url="${HG_WS_URL:-}"
		ignore_paths="${HG_IGNORE_PATHS:-}"
		html_prefs="${HG_HTML_PREFS:-}"
		log_format="${HG_LOG_FORMAT:-}"
	fi

	info "${user}/${domain}: mode=${mode} hestia_stats='${stats}'"
	if [[ -n "${port}" || -n "${unit}" || -n "${ws_url}" ]]; then
		info "  realtime_port='${port}' service='${unit}' ws_url='${ws_url}'"
	fi
	if [[ -n "${ignore_paths}" ]]; then
		info "  ignore_paths='${ignore_paths}'"
	fi
	if [[ -n "${html_prefs}" ]]; then
		info "  html_prefs='${html_prefs}'"
	fi
	if [[ -n "${log_format}" ]]; then
		info "  log_format='${log_format}'"
	fi
}

status_all() {
	local file
	local found="no"
	local DOMAIN=""
	local HG_DOMAIN=""
	local HG_MODE=""
	local HG_PORT=""
	local HG_REPORT_PATH=""
	local HG_UNIT=""
	local HG_USER=""
	local HG_WS_URL=""
	local HG_IGNORE_PATHS=""
	local HG_HTML_PREFS=""
	local HG_LOG_FORMAT=""
	local MODE=""
	local REPORT_PATH=""

	if [[ -d "${STATE_DOMAIN_DIR}" ]]; then
		while IFS= read -r file; do
			found="yes"
			# shellcheck disable=SC1090
			source "${file}"
			info "${HG_USER:-${USER}}/${HG_DOMAIN:-${DOMAIN}}: mode=${HG_MODE:-${MODE}} report=${HG_REPORT_PATH:-${REPORT_PATH}} port=${HG_PORT} service=${HG_UNIT} ws_url=${HG_WS_URL} ignore_paths=${HG_IGNORE_PATHS} html_prefs=${HG_HTML_PREFS} log_format=${HG_LOG_FORMAT}"
		done < <(find "${STATE_DOMAIN_DIR}" -type f -name '*.conf' | sort)
	fi

	[[ "${found}" == "yes" ]] || info "no hestia-goaccess domains enabled"
}

disable_domain() {
	local user="$1"
	local domain="$2"
	local file

	require_domain "${user}" "${domain}"
	file="$(state_file "${user}" "${domain}")"
	if [[ -f "${file}" ]]; then
		stop_realtime_if_present "${user}" "${domain}"
		rm -f "${file}"
		info "disabled hestia-goaccess state for ${user}/${domain}"
	else
		info "${user}/${domain} is not enabled in hestia-goaccess state"
	fi
	info "existing reports are left in place; remove the stats index manually if needed"
}

current_hestia_user() {
	local current

	current="$(id -un 2>/dev/null || true)"
	if [[ -z "${current}" ]]; then
		current="${USER:-}"
	fi
	printf '%s\n' "${current}"
}

terminal_dashboard() {
	local user="$1"
	local domain="$2"
	local log_path
	local file
	local ignore_paths="${GOACCESS_IGNORE_PATHS}"
	local log_format="${GOACCESS_LOG_FORMAT}"

	require_terminal_domain "${user}" "${domain}"
	require_goaccess
	require_filter_log

	log_path="$(domain_log_path "${domain}")"
	[[ -f "${log_path}" ]] || die "access log does not exist: ${log_path}"
	[[ -r "${log_path}" ]] || die "access log is not readable: ${log_path}"

	file="$(state_file "${user}" "${domain}")"
	ignore_paths="$(state_value "${file}" "HG_IGNORE_PATHS" || printf '%s\n' "${GOACCESS_IGNORE_PATHS}")"
	log_format="$(state_value "${file}" "HG_LOG_FORMAT" || printf '%s\n' "${GOACCESS_LOG_FORMAT}")"

	info "Opening GoAccess terminal dashboard for ${user}/${domain}"
	info "Log: ${log_path}"
	info "Press q to quit."
	sleep 1

	HESTIA_GOACCESS_IGNORE_PATHS="${ignore_paths}" "${GOACCESS_FILTER_LOG}" --follow "${log_path}" |
		goaccess - \
			--log-format="${log_format}" \
			--anonymize-ip \
			--no-query-string \
			--ignore-crawlers
}

parse_enable_options() {
	ENABLE_MODE=""
	ENABLE_IGNORE_PATHS="${GOACCESS_IGNORE_PATHS}"
	WS_URL=""

	while [[ "$#" -gt 0 ]]; do
		case "$1" in
			--mode)
				shift
				ENABLE_MODE="${1:-}"
				;;
			--mode=*)
				ENABLE_MODE="${1#--mode=}"
				;;
			--ws-url)
				shift
				WS_URL="${1:-}"
				;;
			--ws-url=*)
				WS_URL="${1#--ws-url=}"
				;;
			--ignore-paths)
				shift
				ENABLE_IGNORE_PATHS="${1:-}"
				;;
			--ignore-paths=*)
				ENABLE_IGNORE_PATHS="${1#--ignore-paths=}"
				;;
			*)
				die "unknown enable option: $1"
				;;
		esac
		shift
	done

	[[ -n "${ENABLE_MODE}" ]] || die "enable requires --mode static or --mode realtime"
	[[ "${ENABLE_MODE}" == "static" || "${ENABLE_MODE}" == "realtime" ]] || die "mode ${ENABLE_MODE} is not implemented yet"
	[[ -n "${ENABLE_IGNORE_PATHS}" ]] || die "--ignore-paths cannot be empty"
}

main() {
	local command="${1:-help}"

	case "${command}" in
		""|-h|--help|help)
			usage
			;;
		doctor)
			shift
			doctor "$@"
			;;
		enable)
			shift
			[[ "$#" -ge 3 ]] || die "usage: hestia-goaccess enable USER DOMAIN --mode static"
			parse_enable_options "${@:3}"
			case "${ENABLE_MODE}" in
				static) enable_static "$1" "$2" ;;
				realtime) enable_realtime "$1" "$2" "${WS_URL}" ;;
			esac
			;;
		disable)
			shift
			[[ "$#" -eq 2 ]] || die "usage: hestia-goaccess disable USER DOMAIN"
			disable_domain "$1" "$2"
			;;
		status)
			shift
			case "$#" in
				0) status_all ;;
				2) status_one "$1" "$2" ;;
				*) die "usage: hestia-goaccess status [USER DOMAIN]" ;;
			esac
			;;
		terminal|term|tui|live)
			shift
			case "$#" in
				1) terminal_dashboard "$(current_hestia_user)" "$1" ;;
				2) terminal_dashboard "$1" "$2" ;;
				*) die "usage: hestia-goaccess terminal [USER] DOMAIN" ;;
			esac
			;;
		*)
			case "$#" in
				1) terminal_dashboard "$(current_hestia_user)" "$1" ;;
				2) terminal_dashboard "$1" "$2" ;;
				*) die "unknown command: ${command}" ;;
			esac
			;;
	esac
}

main "$@"
